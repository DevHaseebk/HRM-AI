# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API key
GEMINI_API_KEY=

# Gmail SMTP (optional — emails skip/fail gracefully if missing)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional — used for links in credential/attendance-reminder emails
NEXT_PUBLIC_APP_URL=

# JWT session signing secret (generate with `openssl rand -base64 32`)
JWT_SECRET=
